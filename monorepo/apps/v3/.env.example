# Copiar para .env.local em dev. Em Railway: Variables (não commitar secrets).

# Obrigatório em produção — mínimo 32 caracteres (ver src/lib/auth.ts)
SESSION_SECRET=

# Senha do /admin (produção: obrigatório forte)
ADMIN_PASSWORD=

# Persistência de propostas (usa a primeira disponível por ordem):
# 1) PostgreSQL — Railway: plugin Postgres → copiar DATABASE_URL para este serviço
DATABASE_URL=
#
# 2) Redis (se não houver DATABASE_URL)
REDIS_URL=

# Opcional: v1 | v2 | v3 quando o host não tem prefixo v1/v2/v3
CMS_DEFAULT_TEMPLATE=v3

# Opcional: diretório de uploads em disco (default conforme src/lib/uploads.ts)
# UPLOAD_DIR=
